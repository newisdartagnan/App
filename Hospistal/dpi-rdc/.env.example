APP_NAME="DPI-RDC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# PostgreSQL — obligatoire en production
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dpi_HGR_KINSHASA_01
DB_USERNAME=dpi_user
DB_PASSWORD=changeme

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# Configuration établissement (multi-tenant Docker)
ESTABLISHMENT_CODE=HGR_KINSHASA_01
ESTABLISHMENT_NAME="Hôpital Général de Kinshasa"
CENTRAL_API_URL=https://central.dpi-rdc.local
CENTRAL_SYNC_TOKEN=
CENTRAL_HOST=central.dpi-rdc.local
CENTRAL_USER=backup
CENTRAL_GPG_KEY=central@dpi-rdc.local

APP_PORT=80
APP_SSL_PORT=443

VITE_APP_NAME="${APP_NAME}"
